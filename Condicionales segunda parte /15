using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ConsoleApplication1
{
    class Program
    {
        static void Main(string[] args)
        {
            Console.Write("ingrese la cantidad de segundos: ");
            int se = Convert.ToInt32(Console.ReadLine());

            if (se > 60)
            {
                int m = se / 60;
                int s = se - (60 * m);
                Console.WriteLine(m + " min con " + s + " segund");
            }
            if (se <= 60)
            {
                Console.WriteLine(se + " segund");
            }
        }
    }
}
